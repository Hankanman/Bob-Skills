{
  "mcpServers": {
    "github": {
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer <GITHUB_PERSONAL_ACCESS_TOKEN>"
      },
      "alwaysAllow": [
        "add_comment_to_pending_review",
        "add_issue_comment",
        "add_reply_to_pull_request_comment",
        "create_branch",
        "create_or_update_file",
        "create_pull_request",
        "delete_file",
        "get_commit",
        "get_file_contents",
        "get_label",
        "get_latest_release",
        "get_me",
        "issue_read",
        "issue_write",
        "list_branches",
        "list_commits",
        "list_issue_fields",
        "list_issue_types",
        "list_issues",
        "list_pull_requests",
        "list_releases",
        "list_repository_collaborators",
        "list_tags",
        "pull_request_read",
        "pull_request_review_write",
        "push_files",
        "request_copilot_review",
        "run_secret_scanning",
        "search_code",
        "search_commits",
        "search_issues",
        "search_pull_requests",
        "search_repositories",
        "search_users",
        "sub_issue_write",
        "update_pull_request",
        "update_pull_request_branch"
      ]
    },
    "tavily": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.tavily.com/mcp/?tavilyApiKey=<INSERT_TAVILY_API_KEY>"
      ],
      "alwaysAllow": [
        "tavily_search",
        "tavily_extract",
        "tavily_crawl",
        "tavily_map",
        "tavily_research"
      ]
    },
    "azure-devops": {
      "command": "npx",
      "args": [
        "-y",
        "@azure-devops/mcp",
        "<YOUR-ADO-ORG-NAME>",
        "--authentication", "pat",
        "-d", "core", "work", "work-items"
      ],
      "env": {
        "PERSONAL_ACCESS_TOKEN": "<base64(email:pat)>"
      },
      "disabled": false
    }
  }
}